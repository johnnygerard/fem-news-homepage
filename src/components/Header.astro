---
import Logo from "~/components/svg/Logo.astro";
import Close from "~/components/svg/icons/Close.astro";
import Menu from "~/components/svg/icons/Menu.astro";
import { navigation } from "~/data/navigation";
import { tw } from "~/utils/tw";
---

<header class="px-4 pt-7 md:px-20 2xl:px-0 2xl:pt-22.25">
  <div class="mx-auto flex items-center justify-between 2xl:w-278">
    <a href="/">
      <span class="sr-only">Go to homepage</span>
      <Logo
        class="h-7 w-11.25 2xl:h-10 2xl:w-16"
        aria-hidden="true"
        focusable="false"
      />
    </a>

    <nav aria-label="Main" class="hidden 2xl:block">
      <ul
        class={tw(
          "flex items-center gap-10",
          "text-[0.9375rem]/[1.625rem] text-navy-600",
        )}
      >
        {
          navigation.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class={tw(
                  "transition-colors hover:text-red-500",
                  href === "/" && "text-navy-950",
                )}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      class="2xl:hidden"
      command="show-modal"
      commandfor="mobile-menu"
      type="button"
    >
      <span class="sr-only">Open menu</span>
      <Menu class="h-4.25 w-10" aria-hidden="true" focusable="false" />
    </button>
  </div>

  <dialog
    id="mobile-menu"
    class={tw(
      "2xl:hidden",
      "m-0 ml-auto h-screen max-h-none w-full max-w-none overflow-hidden",
      "bg-transparent p-0 text-navy-950 backdrop:bg-navy-950/50",
    )}
  >
    <nav
      aria-label="Main"
      class={tw(
        "ml-auto flex h-full w-64 shrink-0 flex-col bg-white px-5.25 pt-6.75",
        "md:w-78 md:pr-20 md:pl-9",
        "text-[1.125rem]/[1.5rem]",
      )}
    >
      <button
        class="ml-auto"
        command="close"
        commandfor="mobile-menu"
        type="button"
      >
        <span class="sr-only">Close menu</span>
        <Close aria-hidden="true" class="size-7" focusable="false" />
      </button>

      <ul class="mt-22 space-y-6">
        {
          navigation.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class={tw("transition-colors", "hover:text-red-500")}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </dialog>
</header>
