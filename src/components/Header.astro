---
import Close from "~/components/svg/icons/Close.astro";
import { navigation } from "~/data/navigation";
import Logo from "~/components/svg/Logo.astro";
import Menu from "~/components/svg/icons/Menu.astro";
import { tw } from "~/utils/tw";
---

<header class="px-4 pt-7">
  <div class="flex items-center justify-between">
    <a href="/" aria-label="Go to homepage">
      <Logo class="h-7 w-11.25" aria-hidden="true" focusable="false" />
    </a>

    <button type="button" aria-label="Open menu" data-menu-open>
      <Menu class="h-4.25 w-10" aria-hidden="true" focusable="false" />
    </button>
  </div>

  <dialog
    id="mobile-menu"
    class={tw(
      "m-0 ml-auto h-screen max-h-none w-full max-w-none overflow-hidden",
      "bg-transparent p-0 text-navy-950 backdrop:bg-navy-950/50",
    )}
  >
    <div class="flex h-full justify-end">
      <button
        type="button"
        aria-label="Close menu"
        data-menu-close
        class="h-full grow"></button>

      <nav
        aria-label="Main navigation"
        class={tw(
          "flex h-full w-64 shrink-0 flex-col bg-white px-5.25 pt-6.75",
          "text-[1.125rem]/[1.5rem]",
        )}
      >
        <button
          type="button"
          aria-label="Close menu"
          data-menu-close
          class="ml-auto"
        >
          <Close class="h-7 w-7" aria-hidden="true" focusable="false" />
        </button>

        <ul class="mt-22 space-y-6">
          {
            navigation.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class={tw("transition-colors", "hover:text-red-500")}
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </dialog>
</header>

<script>
  const menuDialog = document.querySelector<HTMLDialogElement>("#mobile-menu");
  const openButton =
    document.querySelector<HTMLButtonElement>("[data-menu-open]");
  const closeButtons =
    document.querySelectorAll<HTMLButtonElement>("[data-menu-close]");

  if (menuDialog && openButton) {
    openButton.addEventListener("click", () => {
      menuDialog.showModal();
    });

    for (const closeButton of closeButtons) {
      closeButton.addEventListener("click", () => {
        menuDialog.close();
      });
    }
  }
</script>
