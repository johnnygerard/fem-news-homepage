---
/**
 * Image component that uses ImageKit JavaScript SDK for responsive images.
 * @see https://imagekit.io/docs/integration/javascript#responsive-image-logic
 */
import {
  getResponsiveImageAttributes,
  type GetImageAttributesOptions,
} from "@imagekit/javascript";
import type { HTMLAttributes } from "astro/types";
import { inferRemoteSize } from "astro:assets";
import { IMAGEKIT_URL_ENDPOINT } from "astro:env/client";

type Props = Omit<HTMLAttributes<"img">, "srcset" | "height"> & {
  src: string;
  alt: string;
  sizes?: string; // w descriptor
  width?: number; // x descriptor
  transformation?: GetImageAttributesOptions["transformation"];
  isAboveTheFold?: boolean;
  isLCP?: boolean;
};

const {
  src,
  sizes,
  width,
  transformation,
  isAboveTheFold = false,
  isLCP = false,
  decoding,
  fetchpriority,
  loading,
  ...attrs
} = Astro.props;

const options: GetImageAttributesOptions = {
  urlEndpoint: IMAGEKIT_URL_ENDPOINT,
  src,
};

if (sizes !== undefined && width !== undefined)
  throw new Error(
    "Incompatible props: 'sizes' and 'width' cannot be used together.",
  );

if (sizes !== undefined) options.sizes = sizes;
if (width !== undefined) options.width = width;
if (transformation !== undefined) options.transformation = transformation;

const responsiveAttributes = getResponsiveImageAttributes(options);
const resolution = await inferRemoteSize(responsiveAttributes.src);
---

<img
  src={responsiveAttributes.src}
  srcset={responsiveAttributes.srcSet}
  sizes={responsiveAttributes.sizes}
  decoding={decoding ?? "async"}
  fetchpriority={fetchpriority ?? (isLCP ? "high" : "auto")}
  loading={loading ?? (isLCP || isAboveTheFold ? "eager" : "lazy")}
  width={resolution.width}
  height={resolution.height}
  {...attrs}
/>
