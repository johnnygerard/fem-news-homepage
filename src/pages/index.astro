---
import Image from "~/components/Image.astro";
import Layout from "~/layouts/Layout.astro";
import { buttonStyles } from "~/styles/components";
import {
  textPreset2,
  textPreset3,
  textPreset4,
  textPreset5,
  textPreset6,
} from "~/styles/typography";
import { tw } from "~/utils/tw";

const featuredArticles = [
  {
    title: "Hydrogen VS Electric Cars",
    description: "Will hydrogen-fueled cars ever catch up to EVs?",
    href: "/featured-articles/hydrogen-vs-electric-cars",
  },
  {
    title: "The Downsides of AI Artistry",
    description:
      "What are the possible adverse effects of on-demand AI image generation?",
    href: "/featured-articles/the-downsides-of-ai-artistry",
  },
  {
    title: "Is VC Funding Drying Up?",
    description:
      "Private funding by VC firms is down 50% YOY. We take a look at what that means.",
    href: "/featured-articles/is-vc-funding-drying-up",
  },
];

const articles = [
  {
    title: "Reviving Retro PCs",
    description: "What happens when old PCs are given modern upgrades?",
    image: "article-1.png",
    alt: "A collection of retro computing and gaming hardware, including a vintage monitor, keyboard, joystick, and cassette tapes, illuminated by neon blue and pink lighting.",
    href: "/articles/reviving-retro-pcs",
  },
  {
    title: "Top 10 Laptops of 2022",
    description: "Our best picks for various needs and budgets.",
    image: "article-2.png",
    alt: "Close-up macro view of a black mechanical computer keyboard with red backlit keys.",
    href: "/articles/top-10-laptops-of-2022",
  },
  {
    title: "The Growth of Gaming",
    description: "How the pandemic has sparked fresh opportunities.",
    image: "article-3.png",
    alt: "A white video game controller floating in the air above an open hand against a gray background.",
    href: "/articles/the-growth-of-gaming",
  },
];
---

<Layout title="News homepage">
  <div class="px-4 pt-8 pb-20">
    <section class="space-y-6">
      <Image
        src="main-article.png"
        alt="Lego 3D Render"
        isLCP
        class="h-75 w-full object-cover"
      />

      <div class="space-y-6">
        {/* The h1 max width addresses a mismatch between the Figma design */}
        {/* and the browser that causes the text to wrap differently. */}
        <h1 class={tw(textPreset2, "text-navy-950 max-[24rem]:max-w-80")}>
          The Bright Future of Web 3.0?
        </h1>

        <div class="space-y-6">
          <p class={tw(textPreset6, "text-navy-600")}>
            We dive into the next evolution of the web that claims to put the
            power of the platforms back into the hands of the people. But is it
            really fulfilling its promise?
          </p>

          <a href="/articles/the-bright-future-of-web-3-0" class={buttonStyles}>
            Read more
          </a>
        </div>
      </div>
    </section>

    <section class="mt-16 bg-navy-950 px-6 py-4">
      <div class="space-y-8">
        <h2 class={tw(textPreset3, "text-gold-400")}>New</h2>

        <div class="space-y-8">
          {
            featuredArticles.map(({ title, description, href }, index) => (
              <div class="space-y-2">
                <h3 class={tw(textPreset4, "text-white")}>
                  <a href={href} class="transition-colors hover:text-gold-400">
                    {title}
                  </a>
                </h3>
                <p class={tw(textPreset6, "text-grey-300")}>{description}</p>

                {index < featuredArticles.length - 1 && (
                  <hr class="mt-8 border-t border-navy-600" />
                )}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mt-16 space-y-8">
      {
        articles.map(({ image, alt, title, description, href }, index) => (
          <article class="flex items-start gap-6">
            <Image src={image} alt={alt} class="h-32 w-25 object-cover" />
            <div class="space-y-2">
              <p class={tw(textPreset3, "text-red-500")}>
                {String(index + 1).padStart(2, "0")}
              </p>
              <h3 class={tw(textPreset5, "text-navy-950")}>
                <a href={href} class="transition-colors hover:text-red-500">
                  {title}
                </a>
              </h3>
              <p class={tw(textPreset6, "text-navy-600")}>{description}</p>
            </div>
          </article>
        ))
      }
    </section>
  </div>
</Layout>
