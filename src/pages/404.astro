---
import Layout from "~/layouts/Layout.astro";
import { buttonStyles } from "~/styles/components";
import { textPreset2, textPreset6, textPreset7 } from "~/styles/typography";
import { tw } from "~/utils/tw";
---

<Layout title="404 – Page Not Found">
  <div class={tw("mx-auto w-full max-w-xl px-4 py-16")}>
    <hgroup class="space-y-4">
      <p class={tw(textPreset7, "text-navy-600 uppercase")}>404 Error</p>
      <h1 class={tw(textPreset2, "text-navy-950")}>Page Not Found</h1>
    </hgroup>
    <p class={tw(textPreset6, "mt-4 text-navy-600")}>
      Sorry, the page you are looking for does not exist or has been moved.
    </p>

    <div class="mt-8">
      <a href="/" class={buttonStyles}>Back to Home</a>
    </div>
  </div>
</Layout>
